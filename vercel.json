{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node ./artifacts/api-server/build.mjs && pnpm --filter @workspace/phishing-detector run build",
  "outputDirectory": "artifacts/phishing-detector/dist/public",
  "rewrites": [
    {
      "source": "/:path((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
